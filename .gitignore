# Build Results and Output Directories
# -----------------------------------------------------------------------------------
# Standard build output directories
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
[Aa][Rr][Mm]64[Ee][Cc]/
bld/
[Oo]bj/
[Oo]ut/
[Ll]og*/

# Bin directories (all build configurations)
**/[Bb]in/*

# -----------------------------------------------------------------------------------
# Visual Studio and IDE Files
# -----------------------------------------------------------------------------------
# Visual Studio 2015/2017 cache/options directory
.vs/

# Visual Studio 2017 auto generated files
Generated\ Files/

# Visual Studio cache files
# files ending in .cache can be ignored
*.[Cc]ache
# but keep track of directories ending in .cache
!?*.[Cc]ache/

# Visual Studio user-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.env

# Visual Studio 2017 auto generated files
Generated\ Files/

# Visual Studio History (VSHistory) files
.vshistory/

