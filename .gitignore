# Stardew Valley SMAPI Mod .gitignore
# Based on Visual Studio template from https://github.com/github/gitignore/blob/main/VisualStudio.gitignore
# 
# This file specifies intentionally untracked files that should be ignored by Git.
# For more information about .gitignore patterns, see:
# https://git-scm.com/docs/gitignore

# -----------------------------------------------------------------------------------
# Project-Specific Files and Directories (Stardew Valley SMAPI Mod)
# -----------------------------------------------------------------------------------
# Stardew Valley SMAPI mod specific build outputs
**/bin/Debug/
**/bin/Release/
**/bin/DebugPublic/
**/bin/ReleasePublic/
**/obj/
*.deps.json
*.runtimeconfig.json

# Specific build output DLLs
**/bin/Debug/*.dll
**/bin/Release/*.dll
**/bin/DebugPublic/*.dll
**/bin/ReleasePublic/*.dll
**/obj/**/*.dll

# Project-specific temporary and debug files
temp_debug/
VerifyInvalidChars/
*.exe
*[Tt]emp*.cs
*tmp*.cs
*.tmp
*.temp
*[Dd][Ee][Bb][Uu][Gg]*.cs

# Debug test files and temporary directories
debug_test/
temp_test/
temp_check/
check_temp/
TempTest/
test_pattern_dir/

# Mod-specific archives and distribution files
*.zip

